# 8080 avoids conflict with `php artisan serve` (port 8000)
PORT=8080
NODE_ENV=development

JWT_SECRET=replace_with_a_long_random_string
# User tokens default to 7d; admin tokens use 30d (see JWT_EXPIRES_IN_ADMIN)
JWT_EXPIRES_IN=7d
JWT_EXPIRES_IN_ADMIN=30d
SESSION_SECRET=replace_with_another_random_string

# Paste the FULL string from Atlas → Database → your cluster → Connect → Drivers.
# If you only change the database name but keep an old hostname, DNS will still fail (querySrv ENOTFOUND).
# Passwords with @ # etc. must be URL-encoded in the URI.
MONGODB_URI=

# ── Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client (Web) ──
# Authorized redirect URIs (this app): http://127.0.0.1:8000/google/callback
#   (optional duplicate) http://localhost:8000/google/callback — pick ONE host and match .env + VITE_API_URL
# Do NOT use http://localhost:5173 as the only redirect for this server-side OAuth flow.
#
# Authorized JavaScript origins:
#   http://127.0.0.1:8000
#   http://localhost:8000   ← add if you ever use localhost for the API
#   http://localhost:5173
#
# Client secrets: enable only ONE secret; disable/delete the old one after verifying login.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/google/callback

GOOGLE_VERIFY_SSL=true

# Browser origin(s) allowed to call this API (production). Comma-separated for multiple.
# Example (Vercel + local dev): https://your-app.vercel.app,http://localhost:5173
# OAuth redirect after Google uses the *first* URL only — put production first.
# Used for OAuth redirects, email links, and admin-created user login URL
CLIENT_URL=http://localhost:5173,https://resume-builder-frontend-iq3w.onrender.com

# Optional: override CORS list without changing CLIENT_URL (rare)
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Production checklist (Render + Vercel):
# GOOGLE_REDIRECT_URI=https://resumexpert-04tt.onrender.com/google/callback
# CLIENT_URL=https://resume-builder-topaz-zeta.vercel.app
# Google Console → Authorized redirect URIs + JavaScript origins: both Render + Vercel URLs as needed

# Optional: CORS for /uploads (default * for public thumbnails)
# UPLOADS_CORS_ORIGIN=https://resume-builder-topaz-zeta.vercel.app

# Transactional email (Gmail: use an App Password on the MAIL_FROM account)
MAIL_FROM=your_gmail@gmail.com
MAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Optional display name in inbox: MAIL_FROM_DISPLAY_NAME=ResumeXpert
# Optional: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
ADMIN_NOTIFY_EMAI = ankit.k.elsner@gmail.com

